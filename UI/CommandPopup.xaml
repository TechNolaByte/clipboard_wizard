<Window x:Class="ClipboardWizard.UI.CommandPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        Left="-32000" Top="-32000"
        Width="440">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7AA2F7" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="6,6,0,2" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
    </Window.Resources>

    <Border Background="#1E1F26" CornerRadius="8" BorderBrush="#33363F" BorderThickness="1" Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="Black" />
        </Border.Effect>

        <StackPanel>
            <TextBox x:Name="FilterBox"
                     Background="#2A2C36" Foreground="#E5E7EB" CaretBrush="#E5E7EB"
                     BorderBrush="#3A3D48" BorderThickness="1" Padding="6,4" FontSize="13"
                     TextChanged="FilterBox_TextChanged" />

            <!-- Lightweight preview of the current clipboard content: monospace text for text/files,
                 a thumbnail for images. Non-interactive so it never steals keyboard focus. -->
            <Border x:Name="PreviewBorder" Visibility="Collapsed"
                    Background="#15161C" BorderBrush="#2A2C36" BorderThickness="1"
                    CornerRadius="4" Margin="0,6,0,0" Padding="6">
                <StackPanel>
                    <!-- Focusable=False (not IsHitTestVisible=False) so the wheel and the scrollbar
                         work but keyboard focus stays on the filter box for ↑/↓/Enter nav. -->
                    <TextBox x:Name="PreviewText" Visibility="Collapsed"
                             IsReadOnly="True" Focusable="False"
                             Background="Transparent" Foreground="#C8CDD6" BorderThickness="0"
                             FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11.5"
                             MaxHeight="150" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <Image x:Name="PreviewImage" Visibility="Collapsed"
                           MaxHeight="180" Stretch="Uniform" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <ListBox x:Name="CommandList"
                     MaxHeight="360" Margin="0,6,0,0"
                     Background="Transparent" BorderThickness="0"
                     Foreground="#E5E7EB" FontSize="13"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource GroupHeaderStyle}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <!-- Two-column flow within each group. -->
                        <GroupStyle.Panel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                    </GroupStyle>
                </ListBox.GroupStyle>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="Width" Value="198" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Item_Click" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Stretch" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3D59A1" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E3142" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Display}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <!-- Delete button for user scripts (hidden for everything else). -->
                            <Button Grid.Column="1" Content="✕" ToolTip="Delete this script"
                                    Click="DeleteScript_Click" Focusable="False"
                                    Visibility="{Binding IsScript, Converter={StaticResource BoolToVis}}"
                                    Width="18" Height="18" Padding="0" Margin="6,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#C05C6A" Cursor="Hand" FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Border>
</Window>
